{
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/sanjeet/.config/claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/sanjeet/.dotfiles/ai/claude/hooks/claude-nvim-marker.mjs\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context-mode@context-mode": true,
    "architect@andrew-skills": true,
    "obsidian-review@andrew-skills": true,
    "publish-review@andrew-skills": true,
    "defuddle@obsidian-skills": true,
    "json-canvas@obsidian-skills": true,
    "obsidian-bases@obsidian-skills": true,
    "obsidian-cli@obsidian-skills": true,
    "obsidian-markdown@obsidian-skills": true,
    "superpowers@superpowers-skills": true
  },
  "extraKnownMarketplaces": {
    "andrew-skills": {
      "source": {
        "source": "directory",
        "path": "/Users/sanjeet/Developer/andrew-skills"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "directory",
        "path": "/Users/sanjeet/Developer/obsidian-skills"
      }
    },
    "superpowers-skills": {
      "source": {
        "source": "directory",
        "path": "/Users/sanjeet/Developer/superpowers-skills"
      }
    }
  },
  "theme": "dark",
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "llm-wiki": {
      "command": "node",
      "args": [
        "/Users/sanjeet/Developer/llm_wiki/mcp-server/dist/src/index.js"
      ],
      "env": {
        "LLM_WIKI_API_BASE_URL": "http://127.0.0.1:19828"
      }
    }
  }
}
